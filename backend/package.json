{
  "name": "backend",
  "version": "1.0.0",
  "description": "VoteEasy backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --testPathPattern=tests --forceExit",
    "test:coverage": "jest --testPathPattern=tests --coverage --forceExit",
    "lint": "eslint ."
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000
  },
  "dependencies": {
    "@google/generative-ai": "^0.14.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.21.0",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "jest": true
    },
    "extends": "eslint:recommended",
    "rules": {
      "no-console": "off",
      "no-unused-vars": "warn"
    }
  }
}
